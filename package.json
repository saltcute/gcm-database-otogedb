{
    "name": "gcm-database-otogedb",
    "version": "1.0.5",
    "description": "A GekiChuMai Metadata database",
    "homepage": "https://github.com/saltcute/gcm-database-otogedb#readme",
    "bugs": {
        "url": "https://github.com/saltcute/gcm-database-otogedb/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saltcute/gcm-database-otogedb.git"
    },
    "license": "MIT",
    "author": "saltcute",
    "type": "commonjs",
    "exports": {
        "./maimai": "./dist/maimai.js",
        "./chunithm": "./dist/chunithm.js",
        "./ongeki": "./dist/ongeki.js"
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "tsc && tsc-alias",
        "clean": "rimraf dist/*",
        "format": "biome format --write",
        "lint": "biome lint --write",
        "make": "npm run clean && npm run format && npm run lint && npm run build",
        "test": "export LOG_LEVEL=debug && npm run make && node ./test/test.js"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@types/memory-cache": "^0.2.6",
        "@types/node": "^25.9.3",
        "rimraf": "^6.1.3",
        "tsc-alias": "^1.8.17",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "gcm-database": "^1.0.3"
    },
    "dependencies": {
        "@saltcute/cache": "^1.0.2"
    }
}
